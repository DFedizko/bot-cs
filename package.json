{
  "name": "bot-cs",
  "version": "0.0.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsup src --format cjs,esm --dts --clean",
    "dev": "tsx --watch --env-file=.env src/main.ts",
    "start": "node --env-file=.env dist/main.js",
    "format": "prettier --write src test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "tsup": "^8.5.1",
    "tsx": "^4.23.0",
    "typescript-eslint": "^8.63.0"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
